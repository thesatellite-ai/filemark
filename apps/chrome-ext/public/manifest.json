{
  "manifest_version": 3,
  "name": "Filemark",
  "version": "0.1.0",
  "description": "Beautiful in-browser viewer for markdown and other text files. Open local .md / .mdx files directly, organize, search, and read your docs without leaving Chrome.",
  "action": {
    "default_title": "Open Filemark"
  },
  "options_ui": {
    "page": "src/options/index.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["file:///*"],
      "js": ["content.js"],
      "run_at": "document_end",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/app/index.html", "assets/*"],
      "matches": ["file:///*", "<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
